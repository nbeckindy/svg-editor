{
  "name": "svg-editor",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "embed:data-svgs": "node tools/embed-data-svgs.mjs",
    "lint": "eslint src/app/tools src/app/components/svg-canvas/pen-tool-session",
    "lint:arch": "node tools/check-architecture-guards.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/animations": "~21.1.3",
    "@angular/cdk": "~21.1.3",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.1.3",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@mdi/angular-material": "~7.2.96",
    "@svgdotjs/svg.js": "~3.2.5",
    "martinez-polygon-clipping": "~0.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "~2.4.8",
    "@analogjs/vitest-angular": "~2.4.8",
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "~10.0.1",
    "@playwright/test": "~1.51.0",
    "@types/node": "~25.9.1",
    "eslint": "~10.7.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "~8.63.0",
    "vitest": "^4.0.8"
  }
}
